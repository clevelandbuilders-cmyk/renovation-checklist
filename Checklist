/* ── Google Places Autocomplete ── */
function initPlacesAutocomplete() {
  const input = document.getElementById('f_loc');
  if (!input || typeof google === 'undefined') return;
  const ac = new google.maps.places.Autocomplete(input, { types: ['address'], componentRestrictions: { country: 'us' } });
  ac.addListener('place_changed', () => {
    const place = ac.getPlace();
    if (place && place.formatted_address) input.value = place.formatted_address;
  });
}
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initPlacesAutocomplete);
} else {
  initPlacesAutocomplete();
}

