<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --brand: #6b6b5a;
  --brand-light: #8a8a76;
  --text: #1a1a1a;
  --sub: #555;
  --border: #bbb;
  --bg: #f5f5f0;
  --focus-bg: #eef3ff;
  --accent: #3a6fd8;
  --check: 22px;
}
html { font-size: 15px; }
body { font-family: 'Segoe UI', Helvetica, Arial, sans-serif; background: #e0ddd6; color: var(--text); min-height: 100vh; }

/* ── STATUS BANNER (Salesforce connection indicator) ── */
.sf-banner {
  display: none; /* shown by JS when SF connected */
  padding: 8px 14px;
  font-size: 12px;
  font-weight: 600;
  text-align: center;
}
.sf-banner.connected { background: #d4edda; color: #155724; display: block; }
.sf-banner.error { background: #f8d7da; color: #721c24; display: block; }
.sf-banner.loading { background: #fff3cd; color: #856404; display: block; }

/* ── TOP BAR ── */
.top-bar {
  background: var(--brand); color: white;
  display: flex; align-items: center; gap: 12px;
  padding: 13px 15px; position: sticky; top: 0; z-index: 20;
  box-shadow: 0 2px 8px rgba(0,0,0,.3);
}
.pella-badge { border: 2px solid rgba(255,255,255,.8); padding: 2px 8px; font-style: italic; font-size: 16px; font-weight: bold; border-radius: 2px; flex-shrink: 0; }
.top-bar h1 { font-size: 14px; font-weight: 600; line-height: 1.3; flex: 1; }
.sf-indicator { font-size: 11px; background: rgba(255,255,255,.2); border-radius: 4px; padding: 3px 8px; white-space: nowrap; }

/* ── CARDS ── */
.card { background: white; margin: 11px 10px; border-radius: 10px; padding: 15px 14px; box-shadow: 0 1px 5px rgba(0,0,0,.1); }
.card-title { font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .9px; color: var(--brand); margin-bottom: 12px; padding-bottom: 6px; border-bottom: 2px solid var(--brand); }

/* ── FIELDS ── */
.field { margin-bottom: 11px; }
.field label { display: block; font-size: 11px; font-weight: 600; color: var(--sub); margin-bottom: 4px; text-transform: uppercase; letter-spacing: .4px; }
.field input[type=text], .field input[type=date], .field textarea {
  width: 100%; border: 1.5px solid var(--border); border-radius: 6px;
  padding: 10px 11px; font-size: 15px; font-family: inherit;
  background: var(--bg); color: var(--text); outline: none; -webkit-appearance: none;
  transition: border-color .15s, background .15s;
}
.field input:focus, .field textarea:focus { border-color: var(--accent); background: var(--focus-bg); }
.field input[readonly] { background: #ececea; color: #333; font-weight: 600; border-color: #ccc; }
.field textarea { resize: vertical; min-height: 70px; }
/* Salesforce-populated fields get a subtle teal left border */
.field input.sf-populated { border-left: 3px solid #0070d2; background: #f0f8ff; }

/* ── CHECKBOXES ── */
.chk { display: flex; align-items: flex-start; gap: 12px; padding: 9px 0; border-bottom: 1px solid #f0f0ec; cursor: pointer; }
.chk:last-child { border-bottom: none; }
.chk input[type=checkbox] { width: var(--check); height: var(--check); min-width: var(--check); accent-color: var(--brand); cursor: pointer; margin-top: 1px; flex-shrink: 0; }
.chk label { font-size: 14px; line-height: 1.45; cursor: pointer; flex: 1; }
.sub { background: #f7f7f3; border-radius: 8px; padding: 4px 12px; margin: 4px 0; border-left: 3px solid var(--brand-light); }
.sub .chk { padding: 8px 0; }

/* ── SIGNATURE ── */
.sig-lbl { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: var(--sub); margin-bottom: 5px; }
.sig-wrap { border: 1.5px solid var(--border); border-radius: 8px; background: #fafaf8; overflow: hidden; touch-action: none; }
#sigCanvas { display: block; width: 100%; height: 110px; cursor: crosshair; touch-action: none; }
.sig-hint { text-align: center; font-size: 11px; color: #aaa; margin-top: 4px; }
.btn-sm { margin-top: 7px; padding: 8px 16px; font-size: 13px; background: #f0f0ec; border: 1px solid #ccc; border-radius: 6px; cursor: pointer; font-family: inherit; color: #444; }

/* ── ACTION BAR ── */
.action-bar { position: fixed; bottom: 0; left: 0; right: 0; background: var(--brand); padding: 10px 12px; display: flex; gap: 10px; z-index: 30; }
.btn-primary { flex: 1; background: white; color: var(--brand); border: none; padding: 11px; font-size: 14px; font-weight: 700; border-radius: 7px; cursor: pointer; font-family: inherit; }
.btn-sf { flex: 1; background: #0070d2; color: white; border: none; padding: 11px; font-size: 13px; font-weight: 700; border-radius: 7px; cursor: pointer; font-family: inherit; display: none; }
/* Show SF save button when SF is configured */
.sf-enabled .btn-sf { display: block; }

/* ══════════════════════════════════════════
   PRINT / DOCUMENT VIEW
══════════════════════════════════════════ */
#printView { display: none; background: white; font-family: Arial, Helvetica, sans-serif; font-size: 11px; color: #000; }

.doc-header { background: #6b6b5a; color: white; display: flex; align-items: center; gap: 14px; padding: 10px 18px; }
.doc-logo { border: 2px solid white; padding: 3px 9px; font-style: italic; font-size: 17px; font-weight: bold; }
.doc-header h2 { font-size: 20px; font-weight: normal; letter-spacing: .3px; }
.doc-body { padding: 18px 24px 12px; }

.doc-field { display: flex; align-items: flex-end; margin-bottom: 8px; gap: 5px; font-size: 11px; }
.doc-field-label { white-space: nowrap; }
.doc-field-line { flex: 1; border-bottom: 1px solid #333; min-height: 16px; padding-bottom: 1px; font-size: 11px; padding-left: 4px; }

hr.doc-hr { border: none; border-top: 1px solid #ccc; margin: 10px 0; }

.doc-chk { display: flex; align-items: flex-start; gap: 6px; margin-bottom: 5px; font-size: 11px; line-height: 1.4; }
.doc-box { width: 11px; height: 11px; min-width: 11px; border: 1px solid #555; display: inline-flex; align-items: center; justify-content: center; margin-top: 1px; font-size: 9px; font-weight: bold; flex-shrink: 0; }
.doc-box.checked { background: #000; color: white; }

.doc-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 16px; margin-left: 16px; margin-top: 4px; }
.doc-sub { margin-left: 16px; margin-top: 3px; }
.doc-verify { border: 1px solid #aaa; min-height: 32px; padding: 3px 5px; font-size: 10.5px; margin-left: 16px; margin-top: 3px; width: calc(100% - 16px); white-space: pre-wrap; }

.doc-sig-row { display: flex; gap: 20px; align-items: flex-end; margin-top: 18px; border-top: 1px solid #999; padding-top: 12px; }
.doc-sig-box { flex: 2; }
.doc-sig-label { font-size: 10px; color: #555; margin-bottom: 3px; }
.doc-sig-img { border: 1px solid #aaa; height: 60px; width: 100%; display: block; object-fit: contain; }
.doc-right-fields { flex: 1; display: flex; flex-direction: column; gap: 10px; }
.doc-right-field { border-bottom: 1px solid #333; font-size: 11px; padding-bottom: 2px; padding-left: 3px; min-height: 16px; }
.doc-right-field-lbl { font-size: 10px; color: #555; margin-bottom: 2px; }

.doc-footer { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 14px; padding-top: 8px; border-top: 1px solid #ddd; }
.doc-epa { display: flex; align-items: center; gap: 6px; font-size: 10px; color: #2a5a96; font-weight: bold; }
.doc-epa-badge { background: #2a5a96; color: white; font-size: 12px; font-weight: bold; padding: 2px 6px; border-radius: 2px; }
.doc-pella { text-align: right; font-size: 9px; color: #888; }
.doc-pella-logo { font-style: italic; font-size: 12px; font-weight: bold; color: #6b6b5a; border: 1px solid #6b6b5a; padding: 1px 6px; display: inline-block; margin-bottom: 2px; }

.back-bar { background: var(--brand); padding: 10px 14px; display: flex; gap: 10px; }
.btn-back { flex: 1; background: white; color: var(--brand); border: none; padding: 10px; font-size: 14px; font-weight: 700; border-radius: 7px; cursor: pointer; font-family: inherit; }
.btn-print { flex: 1; background: #333; color: white; border: none; padding: 10px; font-size: 14px; font-weight: 700; border-radius: 7px; cursor: pointer; font-family: inherit; }
.btn-sf-save { flex: 1; background: #0070d2; color: white; border: none; padding: 10px; font-size: 13px; font-weight: 700; border-radius: 7px; cursor: pointer; font-family: inherit; display: none; }
.sf-enabled .btn-sf-save { display: block; }

@media print {
  #formView, .back-bar { display: none !important; }
  #printView { display: block !important; }
  body { background: white; }
}
</style>

</head>
