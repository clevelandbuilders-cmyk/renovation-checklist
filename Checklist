/* ── Signature pad ── */
const sigCanvas = document.getElementById('sigCanvas');
const ctx = sigCanvas.getContext('2d');
function resizeCanvas() {
  const w = sigCanvas.offsetWidth, h = 110;
  sigCanvas.width = w * devicePixelRatio; sigCanvas.height = h * devicePixelRatio;
  sigCanvas.style.height = h + 'px';
  ctx.scale(devicePixelRatio, devicePixelRatio);
  ctx.strokeStyle = '#111'; ctx.lineWidth = 2.5; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
}
resizeCanvas();
window.addEventListener('resize', resizeCanvas);
let drawing = false, lx = 0, ly = 0;
function pos(e) {
  const r = sigCanvas.getBoundingClientRect();
  return e.touches ? { x: e.touches[0].clientX-r.left, y: e.touches[0].clientY-r.top }
                   : { x: e.clientX-r.left, y: e.clientY-r.top };
}
sigCanvas.addEventListener('mousedown', e => { drawing=true; const p=pos(e); lx=p.x; ly=p.y; });
sigCanvas.addEventListener('mousemove', e => { if(!drawing) return; const p=pos(e); ctx.beginPath(); ctx.moveTo(lx,ly); ctx.lineTo(p.x,p.y); ctx.stroke(); lx=p.x; ly=p.y; });
sigCanvas.addEventListener('mouseup', ()=>drawing=false);
sigCanvas.addEventListener('mouseleave', ()=>drawing=false);
sigCanvas.addEventListener('touchstart', e=>{ e.preventDefault(); drawing=true; const p=pos(e); lx=p.x; ly=p.y; },{passive:false});
sigCanvas.addEventListener('touchmove', e=>{ e.preventDefault(); if(!drawing) return; const p=pos(e); ctx.beginPath(); ctx.moveTo(lx,ly); ctx.lineTo(p.x,p.y); ctx.stroke(); lx=p.x; ly=p.y; },{passive:false});
sigCanvas.addEventListener('touchend', ()=>drawing=false);
function clearSig() { ctx.clearRect(0,0,sigCanvas.width,sigCanvas.height); }

/* ── Helpers ── */
function val(id) { return (document.getElementById(id)||{}).value || ''; }
function setText(id, text) { const el=document.getElementById(id); if(el) el.textContent=text; }
function setBox(docId, checked) {
  const el = document.getElementById(docId);
  if (!el) return;
  el.textContent = checked ? '✓' : '';
  el.classList.toggle('checked', checked);
}
function formatDate(v) {
  if (!v) return '';
  const [y,m,d] = v.split('-');
  return `${m}/${d}/${y}`;
}

